   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Load and train a 2D model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model = create_custom_unet('resnet18', 1, (128,128), True, n_in=1, cut=4)\n",
    "\n",
    "loss = CombinedLoss(mse_weight=0.8, mae_weight=0.1)\n",
    "\n",
    "metrics = [MSEMetric(), MAEMetric(), SSIMMetric(2)]\n",
    "\n",
    "trainer = fastTrainer(data, model, loss_fn=loss, metrics=metrics, show_summary=False)\n"
   ]
