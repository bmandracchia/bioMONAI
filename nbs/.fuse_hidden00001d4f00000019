   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Download Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "The file has been downloaded and saved to: ../_data/U2OS\n",
      "Decompression (if needed) has been handled automatically.\n"
     ]
    }
   ],
   "source": [
    "# Specify the directory where you want to save the downloaded files\n",
    "output_directory = \"../_data/U2OS\"\n",
    "# Define the base URL for the dataset\n",
    "url = 'http://csbdeep.bioimagecomputing.com/example_data/snr_7_binning_2.zip'\n",
    "\n",
    "# Download only the first two images\n",
    "download_file(url, output_directory, extract=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Create Dataloader"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "train images: 2335 \n",
      "validation images: 122\n"
     ]
    }
   ],
   "source": [
    "\n",
    "X_path = '../_data/U2OS/128a57f165e1044e34d9a6ef46e66b3c-snr_7_binning_2.zip.unzip/train/low/'\n",
    "y_path = '../_data/U2OS/128a57f165e1044e34d9a6ef46e66b3c-snr_7_binning_2.zip.unzip/train/GT'\n",
    "\n",
    "bs = 16\n",
    "patch_size = 128\n",
    "\n",
    "itemTfms = [RandCropND(patch_size), RandRot90(prob=.75), RandFlip(prob=0.75)]\n",
    "batchTfms = [ScaleIntensityPercentiles()]\n",
    "\n",
    "get_target_fn = get_target(y_path, same_filename=True)\n",
    "\n",
    "data = BioDataLoaders.from_folder(\n",
    "    X_path, \n",
    "    get_target_fn, \n",
    "    valid_pct=0.05, \n",
    "    seed=42, \n",
    "    item_tfms=itemTfms,\n",
    "    batch_tfms=batchTfms, \n",
    "    show_summary=False,\n",
    "    bs = bs,\n",
    "    )\n",
    "\n",
    "# print length of training and validation datasets\n",
    "print('train images:', len(data.train_ds.items), '\\nvalidation images:', len(data.valid_ds.items))"
   ]
  },
